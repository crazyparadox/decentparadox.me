---
export interface Props {
  title: string
  description: string
  kind?: 'Screenshot' | 'Diagram' | 'Illustration' | 'Flow'
  height?: number
}

const { title, description, kind = 'Illustration', height = 320 } = Astro.props
---

<figure class="not-prose my-8">
  <div
    class="border-border/70 relative overflow-hidden rounded-2xl border bg-[radial-gradient(circle_at_top_left,rgba(160,160,255,0.14),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(255,190,120,0.12),transparent_28%),linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01))] shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]"
    style={`height:${height}px;`}
  >
    <div
      class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:28px_28px] opacity-50"
    >
    </div>
    <div
      class="border-border/70 absolute inset-5 rounded-[20px] border border-dashed"
    >
    </div>

    <div class="relative flex h-full flex-col justify-between p-6">
      <div class="flex items-center justify-between">
        <span
          class="border-border/70 bg-background/60 text-muted-foreground rounded-full border px-2.5 py-1 text-[11px] tracking-[0.18em] uppercase"
        >
          {kind} Placeholder
        </span>
        <span class="text-muted-foreground/80 text-xs"
          >Reserved for future visual</span
        >
      </div>

      <div class="max-w-2xl">
        <h3 class="text-foreground mb-2 font-serif text-2xl leading-none">
          {title}
        </h3>
        <p class="text-muted-foreground max-w-xl text-sm leading-relaxed">
          {description}
        </p>
      </div>
    </div>
  </div>
  <figcaption class="text-muted-foreground mt-3 text-sm leading-relaxed">
    <span class="text-foreground font-medium">Planned visual:</span>
    {description}
  </figcaption>
</figure>
