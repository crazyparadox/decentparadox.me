# Google AI API Key for Gemini
# Get your API key from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here
WAKATIME_API_KEY=your_wakatime_api_key_here

# Neon Postgres connection string (guestbook)
NEON_DATABASE_URL=your_neon_connection_string_here

# --- /ask AI chat ---
# GitHub OAuth app (gates the chat so visitors can't abuse the AI bill).
# Create one at: https://github.com/settings/developers
#   Homepage URL:               https://decentparadox.me
#   Authorization callback URL: https://decentparadox.me/api/auth/callback
#   (for local dev add a second app/callback: http://localhost:1234/api/auth/callback)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=your_random_session_secret

# Fact0 audit logging API key (https://fact0.io)
FACT0_API_KEY=your_fact0_api_key
